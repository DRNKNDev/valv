<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIconFile</key>
	<string>icon</string>
	<key>NSExtension</key>
	<dict>
		<!-- Xcode's macOS "Action Extension" template defaults to the generic Services
		     extension point (com.apple.ui-services) - not File-Provider-specific. The
		     real extension point for a Finder File Provider context-menu action is
		     com.apple.fileprovider-ui (confirmed against the FileProviderUI.framework
		     headers: FPUIActionExtensionViewController/FPUIActionExtensionContext),
		     with actions declared via NSExtensionFileProviderActions rather than the
		     generic NSExtensionAttributes/NSExtensionActivationRule shape. -->
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.fileprovider-ui</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).ActionViewController</string>
		<key>NSExtensionFileProviderActions</key>
		<array>
			<dict>
				<key>NSExtensionFileProviderActionIdentifier</key>
				<string>com.valv.share</string>
				<key>NSExtensionFileProviderActionName</key>
				<string>Share…</string>
				<!-- design.md's Risks section already accepts a stale-but-offered
				     activation rule as a UX rough edge, not a security gap - the
				     backend's own write-capability check (phase-5-sharing-api) is the
				     real enforcement point. TRUEPREDICATE keeps this simple; the
				     activation-rule-predicate-syntax question was an open item in
				     design.md and there's no dedicated per-item "can share" signal to
				     key a narrower predicate off (no NSFileProviderItemCapabilities
				     case for it - see task 4.9/ipc-fp-api's delta spec). -->
				<key>NSExtensionFileProviderActionActivationRule</key>
				<string>TRUEPREDICATE</string>
			</dict>
		</array>
	</dict>
</dict>
</plist>
