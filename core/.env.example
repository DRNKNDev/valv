VALV_DATABASE_URL=file:./dev.db
VALV_BASE_URL=http://localhost:4747

# Generate VALV_AUTH_SECRET: openssl rand -hex 32
VALV_AUTH_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32

BUCKET_ENDPOINT=http://localhost:9000
BUCKET_NAME=valv-dev
BUCKET_ACCESS_KEY_ID=minioadmin
BUCKET_SECRET_ACCESS_KEY=minioadmin
# Required for local MinIO path-style URLs. Do not set this for Cloudflare R2 or AWS S3.
BUCKET_FORCE_PATH_STYLE=true

# VALV_PORT defaults to 4747.
# VALV_PORT=4747

# SMTP defaults match Cloudflare Email Workers when host/port/user are omitted.
# SMTP_HOST=smtp.mx.cloudflare.net
# SMTP_PORT=465
# SMTP_USER=apitoken
# SMTP_PASS=replace_with_smtp_password_or_api_token
# EMAIL_FROM=Valv <noreply@example.com>

# Local Mailpit SMTP trap. Requires tooling/dev/docker-compose.yml in this monorepo.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=dev
# SMTP_PASS=dev
# EMAIL_FROM=dev@localhost
